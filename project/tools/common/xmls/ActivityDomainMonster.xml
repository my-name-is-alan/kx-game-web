  <text>
    <item id="1" titleText="击败奖励（概率获得）" descText="心智迷失的村落遗民，徘徊迷雾，攻击路人" name="失心村民" spine="gw_pangshuifei"/>
    <item id="2" titleText="击败奖励（概率获得）" descText="曾守土的勇士，今成无魂之兵，盲目攻击" name="失心民兵" spine="gw_pangshuifei"/>
    <item id="3" titleText="击败奖励（概率获得）" descText="正义之魂失落，化为迷雾中的游荡武者" name="失心侠士" spine="gw_pangshuifei"/>
    <item id="4" titleText="击败奖励（概率获得）" descText="灵魂破碎，狂乱无度，曾经的亡命之徒愈发暴躁" name="丧魄狂徒" spine="gw_pangshuifei"/>
    <item id="5" titleText="击败奖励（概率获得）" descText="昔日英豪，今丧魂魄，失控的武力威胁" name="丧魄豪侠" spine="gw_pangshuifei"/>
    <item id="6" titleText="击败奖励（概率获得）" descText="江湖好手携带魔刀之魂，力量失控，四处肆虐" name="丧魄魔刀" spine="gw_pangshuifei"/>
    <item id="7" titleText="击败奖励（概率获得）" descText="琴声惑人心智，操控迷雾，令人闻风丧胆" name="乱心琴魔" spine="gw_pangshuifei"/>
    <item id="8" titleText="击败奖励（概率获得）" descText="武学巅峰，却因疯癫失控，威胁四方" name="癫狂宗师" spine="gw_pangshuifei"/>
    <item id="9" titleText="击败奖励（概率获得）" descText="迷雾深处，白猿身影，智慧与野性的结合体" name="神秘白猿" spine="gw_pangshuifei"/>
    <item id="11" titleText="奖励预览" descText="愤怒之魂，凝聚不散，化作实体，力量狂暴，难以驾驭" name="怒魄" spine="gw_pangshuifei"/>
    <item id="12" titleText="奖励预览" descText="飘渺无依，游荡于世的灵魂，无形无质，难以捉摸。" name="游魂" spine="gw_pangshuifei"/>
    <item id="13" titleText="奖励预览（概率获得）" descText="古老岁月中遗留下的神秘物品，承载着往昔的记忆与力量，等待着有缘人的发现与传承。" name="前人遗物" spine="gw_pangshuifei"/>
    <item id="21" titleText="击败奖励（概率获得）" descText="隐匿于迷雾中，身份成谜的高手" name="神秘玩家" spine="gw_pangshuifei"/>
    <item id="31" titleText="0" descText="雾中出现一个行色匆匆的少女，她说一定要看看他带来的东西，对我们的目标至关重要" name="雾中轻语" spine="gw_pangshuifei"/>
  </text>
